    {
      "type": "text", "id": "role", "x": 40, "y": 100, "width": 700, "height": 18,
      "text": "Right for discovery, wrong when output has to endure — switch on purpose.", "originalText": "Right for discovery, wrong when output has to endure — switch on purpose.",
