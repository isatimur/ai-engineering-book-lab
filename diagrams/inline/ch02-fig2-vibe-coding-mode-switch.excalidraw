    },
    {
      "type": "text", "id": "pr_t", "x": 468, "y": 176, "width": 264, "height": 24,
      "text": "Vibe engineering", "originalText": "Vibe engineering",
      "fontSize": 19, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#065f46", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 3202022, "version": 1, "versionNonce": 3202022, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text", "id": "pr_b", "x": 468, "y": 212, "width": 264, "height": 130,
      "text": "Goal: endurance — output\nyou can maintain & trust.\n\nNeeds:\n  • a framed problem\n  • explicit constraints\n  • review before merge\n  • a test pinning intent", "originalText": "Goal: endurance — output\nyou can maintain & trust.\n\nNeeds:\n  • a framed problem\n  • explicit constraints\n  • review before merge\n  • a test pinning intent",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#065f46", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 3202023, "version": 1, "versionNonce": 3202023, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5
