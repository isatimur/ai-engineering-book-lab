    {
      "type": "text", "id": "pr_h", "x": 468, "y": 156, "width": 264, "height": 16,
      "text": "ENDURE MODE  —  SWITCH TO IT", "originalText": "ENDURE MODE  —  SWITCH TO IT",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
