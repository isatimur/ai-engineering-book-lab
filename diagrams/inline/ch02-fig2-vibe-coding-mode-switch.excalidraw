    {
      "type": "text", "id": "pl_t", "x": 58, "y": 176, "width": 264, "height": 24,
      "text": "Vibe coding", "originalText": "Vibe coding",
      "fontSize": 19, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#92400e", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 3202012, "version": 1, "versionNonce": 3202012, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text", "id": "pl_b", "x": 58, "y": 212, "width": 264, "height": 130,
      "text": "Goal: discovery — learn\nwhat is worth building.\n\nFits:\n  • rough prototypes\n  • interface sketching\n  • internal tools\n  • one-off automation", "originalText": "Goal: discovery — learn\nwhat is worth building.\n\nFits:\n  • rough prototypes\n  • interface sketching\n  • internal tools\n  • one-off automation",
      "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#92400e", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 3202013, "version": 1, "versionNonce": 3202013, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5
    },

