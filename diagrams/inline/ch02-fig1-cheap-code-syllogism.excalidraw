      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4
    },

    {
      "type": "text", "id": "caption", "x": 40, "y": 392, "width": 710, "height": 18,
      "text": "The machine accelerates production — it cannot remove the need to choose.", "originalText": "The machine accelerates production — it cannot remove the need to choose.",
