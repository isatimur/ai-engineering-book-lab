    {
      "type": "text", "id": "ct", "x": 466, "y": 210, "width": 268, "height": 126,
      "text": "Taste, standards, and\nreview matter MORE.\n\nThe scarce skill is now\nquality discrimination.", "originalText": "Taste, standards, and\nreview matter MORE.\n\nThe scarce skill is now\nquality discrimination.",
      "fontSize": 17, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
