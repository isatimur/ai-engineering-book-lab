    {
      "type": "text", "id": "pr_code", "x": 474, "y": 226, "width": 244, "height": 84,
      "text": "Refactor the auth service.\nTriage the support queue.\nInvestigate the failure.\n\n→ verdict: can I ship it?", "originalText": "Refactor the auth service.\nTriage the support queue.\nInvestigate the failure.\n\n→ verdict: can I ship it?",
