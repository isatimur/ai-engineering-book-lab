    {
      "type": "text", "id": "pl_code", "x": 74, "y": 226, "width": 244, "height": 84,
      "text": "Summarize this thread.\nExplain how OAuth works.\nDraft a tweet about X.\n\n→ verdict: was it helpful?", "originalText": "Summarize this thread.\nExplain how OAuth works.\nDraft a tweet about X.\n\n→ verdict: was it helpful?",
