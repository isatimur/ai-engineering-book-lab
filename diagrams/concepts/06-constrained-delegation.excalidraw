    {
      "type": "text", "id": "contract_t", "x": 374, "y": 242, "width": 204, "height": 88,
      "text": "2 · NEGOTIATED CONTRACT\nwhat “done” means, written\nbefore work starts.\ngenerator + evaluator agree\non explicit criteria, not a\nvague prompt",
      "originalText": "2 · NEGOTIATED CONTRACT\nwhat “done” means, written\nbefore work starts.\ngenerator + evaluator agree\non explicit criteria, not a\nvague prompt",
