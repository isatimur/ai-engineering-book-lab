    {
      "type": "text", "id": "definition", "x": 50, "y": 120, "width": 860, "height": 24,
      "text": "Giving agents real, open-ended work behind explicit limits on what they can\nsee, decide, and touch. The constraints are the architecture — not training wheels.",
      "originalText": "Giving agents real, open-ended work behind explicit limits on what they can\nsee, decide, and touch. The constraints are the architecture — not training wheels.",
      "fontSize": 15, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#374151", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 3660005, "version": 1, "versionNonce": 3660005, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4
    },
    {
      "type": "text", "id": "lbl_how", "x": 50, "y": 178, "width": 400, "height": 14,
      "text": "HOW IT WORKS  ·  THE RELIABILITY TRIAD — ALL THREE REQUIRED",
