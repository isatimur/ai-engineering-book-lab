    {
      "type": "text", "id": "evalbox_t", "x": 648, "y": 242, "width": 212, "height": 88,
      "text": "3 · ADVERSARIAL EVAL\na checker that is NOT the\nagent itself. grades work\nagainst the contract.\nblocks the agent from\nmarking its own homework",
