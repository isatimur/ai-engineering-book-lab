    {
      "type": "text", "id": "sd_ev", "x": 68, "y": 498, "width": 784, "height": 72,
      "text": "## spec: rate-limit the /login endpoint\ngoal:        block brute-force without locking out real users\nconstraints: 5 attempts / 15 min per IP; Redis-backed\nacceptance:  6th attempt -> HTTP 429; counter resets after window\nnon-goals:   CAPTCHA, account lockout, IP allowlisting", "originalText": "## spec: rate-limit the /login endpoint\ngoal:        block brute-force without locking out real users\nconstraints: 5 attempts / 15 min per IP; Redis-backed\nacceptance:  6th attempt -> HTTP 429; counter resets after window\nnon-goals:   CAPTCHA, account lockout, IP allowlisting",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 16100026, "version": 1, "versionNonce": 16100026, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5
