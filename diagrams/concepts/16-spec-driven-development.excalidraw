    {
      "type": "text", "id": "sd_caption", "x": 96, "y": 372, "width": 700, "height": 48,
      "text": "A spec is not documentation — it is an alignment artifact. The same contract\nfeeds all three stages: it helps humans agree, keeps agents from sprawling,\nand gives evals a stable target. As generation gets cheap, this matters more.", "originalText": "A spec is not documentation — it is an alignment artifact. The same contract\nfeeds all three stages: it helps humans agree, keeps agents from sprawling,\nand gives evals a stable target. As generation gets cheap, this matters more.",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#475569", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 16100023, "version": 1, "versionNonce": 16100023, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4
    },
