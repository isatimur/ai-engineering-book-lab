    },
    {
      "type": "text", "id": "gr_evidence_txt", "x": 70, "y": 516, "width": 780, "height": 84,
      "text": "// Cypher — multi-hop query a litigation agent runs on Neo4j\nMATCH (p:Party {name: 'Party A'})-[:SIGNED]->(c:Contract)\n      -[:GOVERNED_BY]->(cl:Clause {id: 7})\nRETURN p, c, cl,\n       [n IN nodes(path) | n.source_doc] AS provenance_trail",
      "originalText": "// Cypher — multi-hop query a litigation agent runs on Neo4j\nMATCH (p:Party {name: 'Party A'})-[:SIGNED]->(c:Contract)\n      -[:GOVERNED_BY]->(cl:Clause {id: 7})\nRETURN p, c, cl,\n       [n IN nodes(path) | n.source_doc] AS provenance_trail",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 4090131, "version": 1, "versionNonce": 4090131, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5
    },
