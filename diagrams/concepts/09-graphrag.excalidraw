    {
      "type": "rectangle", "id": "gr_evidence", "x": 50, "y": 500, "width": 820, "height": 116,
      "strokeColor": "#334155", "backgroundColor": "#1e293b", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 4090130, "version": 1, "versionNonce": 4090130, "isDeleted": false,
