    {
      "type": "text", "id": "da_evidence_txt", "x": 70, "y": 514, "width": 780, "height": 96,
      "text": "# Temporal workflow — durable by construction, retries are free\n@workflow.defn\nclass ResearchAgent:\n    @workflow.run\n    async def run(self, task):\n        plan = await workflow.execute_activity(make_plan, task)\n        for step in plan.steps:           # each activity is checkpointed\n            await workflow.execute_activity(do_step, step)",
      "originalText": "# Temporal workflow — durable by construction, retries are free\n@workflow.defn\nclass ResearchAgent:\n    @workflow.run\n    async def run(self, task):\n        plan = await workflow.execute_activity(make_plan, task)\n        for step in plan.steps:           # each activity is checkpointed\n            await workflow.execute_activity(do_step, step)",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#86efac", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 4080136, "version": 1, "versionNonce": 4080136, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5
    },
