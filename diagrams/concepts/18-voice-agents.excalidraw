    {
      "type": "text", "id": "va_turnloop_t", "x": 360, "y": 312, "width": 240, "height": 16,
      "text": "turn-taking · interruption · backchannel", "originalText": "turn-taking · interruption · backchannel",
      "fontSize": 11, "fontFamily": 3, "textAlign": "center", "verticalAlign": "top",
      "strokeColor": "#64748b", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 18100024, "version": 1, "versionNonce": 18100024, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text", "id": "va_caption", "x": 80, "y": 348, "width": 720, "height": 64,
      "text": "Text chat hides latency, awkward pauses, and weak state behind a forgiving UI.\nVoice does not — delay feels broken, interruption feels rude. The hard part is not\nadding ASR + TTS; it is coordinating the loop in realtime. A proven text agent\ncan often be wrapped with a dedicated voice layer instead of rebuilt end-to-end.", "originalText": "Text chat hides latency, awkward pauses, and weak state behind a forgiving UI.\nVoice does not — delay feels broken, interruption feels rude. The hard part is not\nadding ASR + TTS; it is coordinating the loop in realtime. A proven text agent\ncan often be wrapped with a dedicated voice layer instead of rebuilt end-to-end.",
      "fontSize": 12, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#475569", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 18100025, "version": 1, "versionNonce": 18100025, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.4
    },
