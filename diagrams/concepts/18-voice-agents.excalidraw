    {
      "type": "text", "id": "va_ev", "x": 68, "y": 498, "width": 784, "height": 72,
      "text": "latency budget per turn        target  <= 800 ms total\n  ASR + endpointing ......... ~120 ms\n  model reasoning ........... ~250 ms\n  tool call ................. ~330 ms   <- often the slowest hop\n  TTS first-audio ........... ~100 ms", "originalText": "latency budget per turn        target  <= 800 ms total\n  ASR + endpointing ......... ~120 ms\n  model reasoning ........... ~250 ms\n  tool call ................. ~330 ms   <- often the slowest hop\n  TTS first-audio ........... ~100 ms",
      "fontSize": 11, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#e2e8f0", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 18100028, "version": 1, "versionNonce": 18100028, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.5
