    {
      "type": "text", "id": "definition", "x": 50, "y": 120, "width": 860, "height": 24,
      "text": "Two ways a durable agent survives crashes and resumes long tasks —\nrebuild state by replaying an event history, or resume from a saved snapshot.",
      "originalText": "Two ways a durable agent survives crashes and resumes long tasks —\nrebuild state by replaying an event history, or resume from a saved snapshot.",
