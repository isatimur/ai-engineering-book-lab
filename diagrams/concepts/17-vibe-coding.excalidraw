      "type": "text", "id": "vc_ev_bad", "x": 68, "y": 500, "width": 400, "height": 64,
      "text": "# vibe coded, shipped unexamined\nfn charge(u) { stripe.charge(u.card, u.amt) }\n  # no auth check, no idempotency key\n  # no test -> double-charges on retry", "originalText": "# vibe coded, shipped unexamined\nfn charge(u) { stripe.charge(u.card, u.amt) }\n  # no auth check, no idempotency key\n  # no test -> double-charges on retry",
