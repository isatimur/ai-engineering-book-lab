{
  "overview": [
    {
      "id": "spine",
      "title": "The Argument Spine",
      "caption": "The ten chapters as a four-act dependency arc \u2014 the Problem (ch 1\u20132), the Scaffolding Stack (ch 3\u20137), the Stress Test (ch 8), and the Widening (ch 9\u201310). The book is an argument with a shape, not a survey, and it carries the throughline from possibility to compounding trust.",
      "src": "/diagrams/overview/spine.png",
      "sourceFile": "01-book-argument-spine.excalidraw"
    },
    {
      "id": "machine",
      "title": "The Autoresearch Knowledge Machine",
      "caption": "How a growing video corpus becomes a source-backed book: a five-layer pipeline \u2014 Source \u2192 Synthesis \u2192 Evidence \u2192 Manuscript \u2014 governed by a Research-Org control plane that improves the upper layers through bounded, logged agent passes. Live corpus size in STATS.md.",
      "src": "/diagrams/overview/machine.png",
      "sourceFile": "02-autoresearch-machine.excalidraw"
    },
    {
      "id": "stack",
      "title": "The Scaffolding Stack",
      "caption": "The book's central thesis in one picture: a raw model is capable but not dependable. Five engineered layers wrap it \u2014 harnesses, evals, context, runtimes, security \u2014 and each one earns its place by a specific failure it prevents.",
      "src": "/diagrams/overview/stack.png",
      "sourceFile": "03-scaffolding-stack.excalidraw"
    },
    {
      "id": "corpus-map",
      "title": "Theme & Corpus Map",
      "caption": "What the corpus is actually about: ten themes sized by video count, colour-coded by the book act they feed, each mapped to its chapter \u2014 including the honest editorial call that Models & Inference is deliberately background, not a chapter.",
      "src": "/diagrams/overview/corpus-map.png",
      "sourceFile": "04-theme-corpus-map.excalidraw"
    }
  ],
