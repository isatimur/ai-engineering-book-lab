{
  "name": "from-copilot-to-colleague-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "sync-diagrams": "node scripts/sync-diagrams.mjs",
    "gen-data": "node scripts/gen-data.mjs",
    "gen-sitemap": "node scripts/gen-sitemap.mjs",
    "gen-llms": "node scripts/gen-llms.mjs",
    "sync-audio": "node scripts/sync-audio.mjs",
    "prebuild": "node scripts/sync-diagrams.mjs && node scripts/sync-audio.mjs && node scripts/gen-data.mjs && node scripts/gen-sitemap.mjs && node scripts/gen-llms.mjs",
    "build": "vite-react-ssg build",
    "preview": "vite preview",
    "start": "node server.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/diff": "^7.0.2",
    "@vitejs/plugin-react": "^5.0.4",
    "diff": "^9.0.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^6.30.4",
    "vite": "^6.2.3",
    "vite-react-ssg": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^2.1.9"
  }
}
